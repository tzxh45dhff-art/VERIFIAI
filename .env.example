# VerifAI Environment Variables
# Copy this file to backend/.env and fill in your keys

# Required: Groq API key for LLM inference
GROQ_API_KEY=your_groq_api_key_here

# JWT secret for auth tokens
JWT_SECRET=verifai_jwt_secret_change_me

# Frontend API URL (used in docker-compose)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Upload limits
MAX_FILE_SIZE_MB=10

# Free plan monthly limits
FREE_PLAN_MONTHLY_AUDITS=5
FREE_PLAN_MONTHLY_BIAS=3
FREE_PLAN_MONTHLY_CONTEST=2
